---
interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <rect x="4" y="6" width="24" height="20" rx="2.5" stroke="#212529" stroke-width="2"></rect>
  <line x1="9" y1="22" x2="22" y2="10" stroke="#212529" stroke-width="2" stroke-linecap="round"></line>
  <circle cx="22" cy="10" r="2" fill="#2d70b3"></circle>
</svg>
