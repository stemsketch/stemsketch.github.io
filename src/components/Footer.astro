---
import { NAV, LINKS, SITE } from '../config/site.ts';
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <strong>{SITE.name}</strong>
      <p>{SITE.tagline}</p>
    </div>
    <div>
      <h2 class="site-footer__heading">Product</h2>
      <ul class="site-footer__list">
        {
          NAV.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))
        }
        <li><a href={LINKS.editor}>Open editor</a></li>
      </ul>
    </div>
    <div>
      <h2 class="site-footer__heading">Account</h2>
      <ul class="site-footer__list">
        <li><a href={LINKS.signup}>Sign up</a></li>
        <li><a href={LINKS.login}>Log in</a></li>
        <li><a href="/pricing">Pricing</a></li>
      </ul>
    </div>
    <div>
      <h2 class="site-footer__heading">Legal</h2>
      <ul class="site-footer__list">
        <li><a href="/legal">Legal hub</a></li>
        <li><a href={LINKS.terms}>Terms</a></li>
        <li><a href={LINKS.privacy}>Privacy</a></li>
      </ul>
    </div>
  </div>
  <div class="container site-footer__bottom">
    <span>&copy; {new Date().getFullYear()} STEMSketch</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: 4rem 0 1.5rem;
    background: var(--ss-text-primary);
    color: #cbd5e1;
  }

  .site-footer__grid {
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .site-footer__grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .site-footer__brand strong {
    display: block;
    color: #fff;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .site-footer__brand p {
    margin: 0.65rem 0 0;
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 20rem;
    color: #94a3b8;
  }

  .site-footer__heading {
    margin: 0 0 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer__list li {
    margin-bottom: 0.5rem;
  }

  .site-footer__list a {
    color: #e2e8f0;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.15s;
  }

  .site-footer__list a:hover {
    color: #fff;
  }

  .site-footer__bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #334155;
    color: #64748b;
    font-size: 0.85rem;
  }
</style>
