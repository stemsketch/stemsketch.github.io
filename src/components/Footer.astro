---
import { NAV, LINKS, SITE } from '../config/site.ts';
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <strong>{SITE.name}</strong>
      <p class="site-footer__tagline">{SITE.tagline}</p>
    </div>
    <div>
      <h2 class="site-footer__heading">Product</h2>
      <ul class="site-footer__list">
        {
          NAV.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
        <li>
          <a href={LINKS.editor}>Open editor</a>
        </li>
      </ul>
    </div>
    <div>
      <h2 class="site-footer__heading">Resources</h2>
      <ul class="site-footer__list">
        <li><a href={LINKS.appRepo} rel="noopener noreferrer">GitHub</a></li>
        <li><a href={LINKS.architecture} rel="noopener noreferrer">Architecture</a></li>
        <li><a href={LINKS.authorStudio} rel="noopener noreferrer">Author studio</a></li>
      </ul>
    </div>
    <div>
      <h2 class="site-footer__heading">Legal</h2>
      <ul class="site-footer__list">
        <li><a href="/legal">Legal hub</a></li>
        <li><a href={LINKS.terms}>Terms</a></li>
        <li><a href={LINKS.privacy}>Privacy</a></li>
      </ul>
    </div>
  </div>
  <div class="container site-footer__bottom">
    <span>&copy; {new Date().getFullYear()} STEMSketch</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: 3rem 0 1.5rem;
    background: var(--ss-bg-panel);
    border-top: 1px solid var(--ss-border);
  }

  .site-footer__grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .site-footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
    }
  }

  .site-footer__tagline {
    margin: 0.5rem 0 0;
    color: var(--ss-text-secondary);
    font-size: 0.9rem;
    max-width: 22rem;
  }

  .site-footer__heading {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ss-text-secondary);
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer__list li {
    margin-bottom: 0.45rem;
  }

  .site-footer__list a {
    color: var(--ss-text-primary);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .site-footer__list a:hover {
    color: var(--ss-accent);
  }

  .site-footer__bottom {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--ss-border);
    color: var(--ss-text-muted);
    font-size: 0.85rem;
  }
</style>
