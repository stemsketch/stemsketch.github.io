---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  class?: string;
  external?: boolean;
}

const { href, variant = 'primary', class: className = '', external = false } = Astro.props;
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<a href={href} class={`btn btn--${variant} ${className ?? ''}`} rel={rel} target={target}>
  <slot />
</a>
