---
import type { Plan } from '../data/content.ts';
import Button from './Button.astro';

interface Props {
  plan: Plan;
}

const { plan } = Astro.props;
---

<article class={`card pricing-card ${plan.highlighted ? 'pricing-card--highlight' : ''}`}>
  {plan.highlighted && <span class="pricing-card__badge">Popular</span>}
  <div class="pricing-card__head">
    <h3>{plan.name}</h3>
    <p class="pricing-card__desc">{plan.description}</p>
  </div>
  <div class="pricing-card__price-row">
    <span class="pricing-card__price">{plan.price}</span>
    {plan.priceNote && <span class="pricing-card__note">{plan.priceNote}</span>}
  </div>
  <ul class="pricing-card__features">
    {plan.features.map((feature) => (
      <li>{feature}</li>
    ))}
  </ul>
  <Button href={plan.ctaHref} variant={plan.highlighted ? 'primary' : 'secondary'} class="pricing-card__cta">
    {plan.cta}
  </Button>
</article>

<style>
  .pricing-card__head {
    min-height: 7.5rem;
  }

  .pricing-card h3 {
    margin: 0 0 0.55rem;
    font-size: 1.15rem;
    letter-spacing: 0;
  }

  .pricing-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    min-height: 3.25rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--ss-border);
  }

  .pricing-card__features {
    margin: 0 0 1.5rem;
    padding: 0;
    list-style: none;
    font-size: 0.9rem;
    color: var(--ss-text-secondary);
  }

  .pricing-card__features li {
    padding: 0.4rem 0 0.4rem 1.65rem;
    position: relative;
  }

  .pricing-card__features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    background: var(--ss-accent-muted);
    box-shadow: inset 0 0 0 4px #fff;
  }
</style>
