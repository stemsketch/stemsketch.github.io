---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import HeroVisual from '../components/HeroVisual.astro';
import { FEATURES, HOW_IT_WORKS, SUBJECT_AREAS } from '../data/content.ts';
import { LINKS, SITE } from '../config/site.ts';
---

<BaseLayout>
  <section class="hero hero--split">
    <div class="container">
      <div>
        <p class="eyebrow">For educators & presenters</p>
        <h1 class="hero__title">
          Animated STEM lessons, <em>without the code</em>
        </h1>
        <p class="hero__lead">{SITE.tagline}</p>
        <div class="hero__actions">
          <Button href={LINKS.signup} class="btn--lg">Get started free</Button>
          <Button href={LINKS.editor} variant="secondary" class="btn--lg">Open editor</Button>
        </div>
        <div class="hero__stats">
          <div class="hero__stat">
            <strong>12+</strong>
            <span>STEM subject areas</span>
          </div>
          <div class="hero__stat">
            <strong>MP4 & PPTX</strong>
            <span>Export in browser</span>
          </div>
          <div class="hero__stat">
            <strong>Free tier</strong>
            <span>No credit card</span>
          </div>
        </div>
      </div>
      <HeroVisual />
    </div>
  </section>

  <section class="section">
    <div class="container text-center">
      <p class="eyebrow">Why STEMSketch</p>
      <h2 class="section__title">Everything you need to teach with motion</h2>
      <p class="section__lead">Official templates, a slide-based editor, and one-click export — built for classrooms and conference talks.</p>
      <div class="grid-4">
        {
          FEATURES.map((f) => (
            <article class="card">
              <div class="card__icon">{f.icon}</div>
              <h3>{f.title}</h3>
              <p>{f.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Workflow</p>
      <h2 class="section__title">Three steps to a finished lesson</h2>
      <div class="grid-3">
        {
          HOW_IT_WORKS.map((step) => (
            <article class="card">
              <span class="step-num">{step.step}</span>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container text-center">
      <p class="eyebrow">Catalog</p>
      <h2 class="section__title">Cover the subjects you teach</h2>
      <p class="section__lead">Browse official packs in the editor — from pendulums and DNA to engineering diagrams.</p>
      <div class="grid-3">
        {
          SUBJECT_AREAS.map((area) => (
            <article class="card">
              <h3>{area.label}</h3>
              <p>{area.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Ready for your first ViewDeck?</h2>
      <p>Sign up free, drag a template, and export your first animated lesson today.</p>
      <Button href={LINKS.signup} class="btn--lg">Create free account</Button>
    </div>
  </section>
</BaseLayout>
