---
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import Button from '../components/Button.astro';
import { GUIDES } from '../data/content.ts';
import { LINKS } from '../config/site.ts';
---

<BaseLayout
  title="Help"
  description="How to use STEMSketch — getting started guides, export tips, and frequently asked questions."
>
  <section class="hero hero--center">
    <div class="container">
      <p class="eyebrow">Help center</p>
      <h1 class="hero__title">How to use STEMSketch</h1>
      <p class="hero__lead">
        Step-by-step guides for building lessons, exporting video, and saving to the cloud. New here? Start with Getting started below.
      </p>
      <div class="hero__actions">
        <Button href={LINKS.editor} class="btn--lg">Open editor</Button>
        <Button href="#faq" variant="secondary" class="btn--lg">Jump to FAQ</Button>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow">
      <nav class="guide-nav" aria-label="Guide sections">
        {GUIDES.map((g) => <a href={`#${g.id}`}>{g.title}</a>)}
        <a href="#faq">FAQ</a>
      </nav>

      {
        GUIDES.map((guide) => (
          <article class="guide-block" id={guide.id}>
            <h3>{guide.title}</h3>
            <ol>
              {guide.steps.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </article>
        ))
      }
    </div>
  </section>

  <Faq />

  <section class="cta-band">
    <div class="container">
      <h2>Still stuck?</h2>
      <p>Reach out and we will help you get your first lesson exported.</p>
      <Button href={LINKS.contact} class="btn--lg">Contact support</Button>
    </div>
  </section>
</BaseLayout>
