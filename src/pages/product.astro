---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { LINKS } from '../config/site.ts';
---

<BaseLayout
  title="Features"
  description="STEMSketch editor features — catalog templates, slides, timeline, Team ViewDeck sync, and export to MP4 or PowerPoint."
>
  <section class="hero hero--center">
    <div class="container">
      <p class="eyebrow">Features</p>
      <h1 class="hero__title">Your studio for animated STEM lessons</h1>
      <p class="hero__lead">
        A browser-based editor with an official template catalog, multi-slide composition, and export tools built for educators — not developers.
      </p>
      <div class="hero__actions">
        <Button href={LINKS.editor} class="btn--lg">Try the editor</Button>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Templates</p>
      <h2 class="section__title">Drag, tune, preview</h2>
      <p class="section__lead">Every template ships with sensible defaults. Adjust values in the properties panel and watch the animation update live.</p>
      <div class="grid-2">
        <article class="card">
          <div class="card__icon">📚</div>
          <h3>Official catalog</h3>
          <p>Browse STEM packs grouped by subject — biology, physics, chemistry, engineering, and more.</p>
        </article>
        <article class="card">
          <div class="card__icon">🎛️</div>
          <h3>Parameter controls</h3>
          <p>Length, angle, speed, and domain-specific fields appear as labeled inputs with helpful min/max hints.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Composition</p>
      <h2 class="section__title">Slides, layers & timeline</h2>
      <div class="grid-3">
        <article class="card">
          <div class="card__icon">🎞️</div>
          <h3>Slide filmstrip</h3>
          <p>Add, duplicate, and reorder slides. Set cut, fade, or morph transitions between them.</p>
        </article>
        <article class="card">
          <div class="card__icon">⏱️</div>
          <h3>Shared timeline</h3>
          <p>Scrub playback, jump to slide boundaries, and select layers from one timeline across the deck.</p>
        </article>
        <article class="card">
          <div class="card__icon">📑</div>
          <h3>Layers panel</h3>
          <p>Focus, hide, reorder, and copy artifacts between slides in multi-layer lessons.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Sync (Team)</p>
      <h2 class="section__title">Save & sync ViewDecks</h2>
      <p class="section__lead">All users sign in with SSO. Free and Starter accounts save `.viewdeck` files locally; Team workspaces save ViewDecks server-side with concurrent editing and 5 GB storage per user.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Export</p>
      <h2 class="section__title">Take it to the classroom</h2>
      <div class="grid-3">
        <article class="card">
          <div class="card__icon">🎥</div>
          <h3>MP4 video</h3>
          <p>Render directly in Chrome or Edge. Free exports include a watermark and are capped at 60 seconds; paid plans remove both limits.</p>
        </article>
        <article class="card">
          <div class="card__icon">📊</div>
          <h3>PowerPoint</h3>
          <p>Hybrid export: static shapes, native transitions, or embedded video per slide.</p>
        </article>
        <article class="card">
          <div class="card__icon">📦</div>
          <h3>ViewDeck file</h3>
          <p>Portable `.viewdeck` project files for backup, import, or view-only sharing.</p>
        </article>
      </div>
      <p class="footnote">Starter removes video watermarks and length limits. Team adds server-side ViewDeck saves and concurrent editing. <a href="/pricing">Compare plans</a></p>
    </div>
  </section>
</BaseLayout>
