---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import PlanTable from '../components/PlanTable.astro';
import { PLANS } from '../data/content.ts';
---

<BaseLayout
  title="Pricing"
  description="STEMSketch plans for educators — Free, Pro, Team, and Enterprise. Compare storage, collaboration, and export options."
>
  <section class="hero hero--center">
    <div class="container">
      <p class="eyebrow">Pricing</p>
      <h1 class="hero__title">Plans for every classroom</h1>
      <p class="hero__lead">
        Start free with local `.viewdeck` saves. Upgrade to Pro for cloud storage, or Team for realtime collaboration.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 0">
    <div class="container">
      <div class="grid-4">
        {PLANS.map((plan) => <PricingCard plan={plan} />)}
      </div>
      <PlanTable />
      <p class="footnote">
        Paid plans are available in the editor when billing is enabled. Enterprise includes SSO and SCIM — <a href="mailto:hello@stemsketch.dev">contact us</a> for a quote.
      </p>
    </div>
  </section>
</BaseLayout>
