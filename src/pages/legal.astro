---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { APP_ORIGIN, LINKS } from '../config/site.ts';
---

<BaseLayout title="Legal" description="STEMSketch legal information and links to terms and privacy.">
  <section class="hero hero--center">
    <div class="container">
      <p class="eyebrow">Legal</p>
      <h1 class="hero__title">Terms & privacy</h1>
      <p class="hero__lead">Legal documents for the STEMSketch application are hosted on our production app.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <article class="card">
          <div class="card__icon">📄</div>
          <h3>Terms of service</h3>
          <p>Usage terms for the STEMSketch editor and platform services.</p>
          <p style="margin-top: 1.25rem">
            <Button href={LINKS.terms} external>View terms</Button>
          </p>
        </article>
        <article class="card">
          <div class="card__icon">🔒</div>
          <h3>Privacy policy</h3>
          <p>How we handle account data, local projects, and Team server-side ViewDeck storage.</p>
          <p style="margin-top: 1.25rem">
            <Button href={LINKS.privacy} variant="secondary" external>View privacy policy</Button>
          </p>
        </article>
      </div>
      <p class="footnote">
        The interactive application runs at <a href={APP_ORIGIN}>anime.os20.org</a>. This page is part of the STEMSketch marketing site.
      </p>
    </div>
  </section>
</BaseLayout>
